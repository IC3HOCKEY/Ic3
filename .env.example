# --- Shopify Storefront API (headless) ---
# Your myshopify.com domain, e.g. ic3sweden.myshopify.com (NOT the custom domain).
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Public Storefront API token (used only server-side from route handlers).
# Create in Shopify Admin → Settings → Apps and sales channels → Develop apps
#  → Create app → Configure Storefront API access → Install app → API credentials.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Storefront API version — pin to a dated release (e.g. 2024-10) when you are ready.
SHOPIFY_API_VERSION=2024-10

# Public URL of the site (used for canonical tags, OG, sitemap).
NEXT_PUBLIC_SITE_URL=https://ic3sweden.se

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=

# Optional: Klaviyo company id for newsletter embed
NEXT_PUBLIC_KLAVIYO_COMPANY_ID=
